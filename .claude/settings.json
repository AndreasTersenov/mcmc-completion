{
  "permissions": {
    "allow": [
      "Bash(python *)", "Bash(python3 *)", "Bash(pytest *)", "Bash(python -m pytest *)",
      "Bash(pip install *)", "Bash(pip list*)", "Bash(source *)", "Bash(module load *)",
      "Bash(git add *)", "Bash(git commit *)", "Bash(git status*)", "Bash(git log *)",
      "Bash(git diff *)", "Bash(git push)", "Bash(git push origin *)",
      "Bash(sbatch *)", "Bash(squeue *)", "Bash(sacct *)", "Bash(scancel *)",
      "Bash(ls *)", "Bash(mkdir *)"
    ],
    "deny": [
      "Bash(rm -rf *)", "Bash(git push --force*)", "Bash(git reset --hard*)"
    ]
  },
  "hooks": {
    "Stop": [
      { "matcher": "*",
        "hooks": [ { "type": "command", "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/test-gate.sh", "timeout": 300 } ] }
    ]
  }
}
